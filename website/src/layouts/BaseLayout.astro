---
// BaseLayout.astro — shell for all yakcc website pages
// Zero client JS: no framework scripts shipped.
const { title = 'yakcc' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        background: #020617;
        color: #f1f5f9;
        min-height: 100vh;
      }
      nav {
        border-bottom: 1px solid #1e293b;
        padding: 0.75rem 2rem;
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }
      nav a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.85rem;
      }
      nav a:hover { color: #f1f5f9; }
      nav .logo { color: #f1f5f9; font-weight: 700; font-size: 1rem; }
      main { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">yakcc</a>
      <a href="/benchmarks">benchmarks</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
