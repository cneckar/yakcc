{
  "name": "@yakcc/variance",
  "version": "0.6.0-alpha.0",
  "description": "Variance scoring and star-topology contract design rules for Yakcc specs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/variance"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/variance#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "variance",
    "scoring",
    "typescript"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@yakcc/contracts": "workspace:*",
    "fast-check": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
