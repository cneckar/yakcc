{
  "name": "@yakcc/hooks-base",
  "version": "0.6.0-alpha.0",
  "description": "Shared types and registry-query logic for all Yakcc IDE hooks — import classification, telemetry, and enforcement config.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/import-classifier.js": "./dist/import-classifier.js",
    "./telemetry.js": { "import": "./dist/telemetry.js", "types": "./dist/telemetry.d.ts" },
    "./telemetry-wire.js": { "import": "./dist/telemetry-wire.js", "types": "./dist/telemetry-wire.d.ts" }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/hooks-base"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/hooks-base#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "hooks",
    "ide",
    "telemetry",
    "typescript"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "echo \"no lint yet\""
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@yakcc/contracts": "workspace:*",
    "@yakcc/ir": "workspace:*",
    "@yakcc/registry": "workspace:*",
    "@yakcc/shave": "workspace:*",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^4.1.5"
  }
}
