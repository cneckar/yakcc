{
  "name": "@yakcc/discovery-search",
  "version": "0.1.0-alpha.0",
  "description": "Browser-safe semantic-search kit for the Yakcc atom explorer — bge-small embedder, cosine scoring, and confidence-tier derivation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "private": true,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/discovery-search"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/discovery-search#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "discovery",
    "search",
    "embeddings",
    "browser"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "lint": "biome check --fix src/ && biome check src/"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "@yakcc/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^4.1.5"
  }
