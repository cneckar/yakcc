{
  "name": "@yakcc/ir",
  "version": "0.5.0-alpha.0",
  "description": "Intermediate representation for strict-TypeScript-subset basic blocks used in the Yakcc universalizer pipeline.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/ir"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/ir#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "ir",
    "intermediate-representation",
    "typescript",
    "ast"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "lint": "biome check src/",
    "strict-subset": "node dist/strict-subset-cli.js"
  },
  "dependencies": {
    "@yakcc/contracts": "workspace:*",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^4.7.0",
    "vitest": "^4.1.5"
  }
}
