{
  "name": "@yakcc/federation",
  "version": "0.6.0-alpha.0",
  "description": "F1 read-only content-addressed block mirror for Yakcc registries — HTTP transport and local/remote pull primitives.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "private": true,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/federation"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/federation#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "federation",
    "registry",
    "content-addressed"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "lint": "echo \"no lint yet\""
  },
  "dependencies": {
    "@yakcc/contracts": "workspace:*",
    "@yakcc/registry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yakcc/shave": "workspace:*",
    "fast-check": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
