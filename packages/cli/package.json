{
  "name": "@yakcc/cli",
  "version": "0.5.0-alpha.0",
  "description": "Yakcc — content-addressed block registry for assembling programs from verified, reusable building blocks.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cneckar/yakcc.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cneckar/yakcc#readme",
  "bugs": "https://github.com/cneckar/yakcc/issues",
  "keywords": [
    "yakcc",
    "code-generation",
    "content-addressed",
    "registry",
    "claude-code",
    "cursor",
    "cline",
    "continue.dev",
    "windsurf",
    "aider",
    "ai-coding"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "yakcc": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSE-ATOMS"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "build:publish": "rm -rf dist && tsup && node scripts/copy-seed-blocks.mjs && node scripts/sync-publish-assets.mjs",
    "build:binary": "node scripts/build-binary.mjs",
    "prepublishOnly": "pnpm run build:publish",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@xenova/transformers": "^2.17.2",
    "assemblyscript": "^0.27.0",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@yakcc/compile": "workspace:*",
    "@yakcc/contracts": "workspace:*",
    "@yakcc/federation": "workspace:*",
    "@yakcc/hooks-base": "workspace:*",
    "@yakcc/hooks-claude-code": "workspace:*",
    "@yakcc/ir": "workspace:*",
    "@yakcc/registry": "workspace:*",
    "@yakcc/seeds": "workspace:*",
    "@yakcc/shave": "workspace:*",
    "@yakcc/variance": "workspace:*",
    "@yao-pkg/pkg": "^6.19.0",
    "fast-check": "^4.7.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
