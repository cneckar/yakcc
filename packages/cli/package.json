    "build:binary": "node scripts/build-binary.mjs",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "lint": "biome check src/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yakcc/seeds": "workspace:*",
    "@yao-pkg/pkg": "^6.19.0",
    "fast-check": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@yakcc/compile": "workspace:*",
    "@yakcc/contracts": "workspace:*",
    "@yakcc/federation": "workspace:*",
    "@yakcc/hooks-claude-code": "workspace:*",
    "@yakcc/ir": "workspace:*",
    "@yakcc/registry": "workspace:*",
    "@yakcc/seeds": "workspace:*",
    "@yakcc/shave": "workspace:*"
  }
}
