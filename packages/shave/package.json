{
  "name": "@yakcc/shave",
  "version": "0.5.0-alpha.0",
  "description": "The universalizer pipeline — decompose a TypeScript/JavaScript source file into content-addressed Yakcc registry atoms.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/shave"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/shave#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "shave",
    "universalizer",
    "typescript",
    "ast"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@noble/hashes": "^1.5.0",
    "@yakcc/variance": "workspace:*",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "@yakcc/contracts": "workspace:*",
    "@yakcc/ir": "workspace:*",
    "@yakcc/registry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^3.23.2",
    "vitest": "^4.1.5"
  }
}
