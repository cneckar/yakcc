{
  "name": "@yakcc/contracts",
  "version": "0.6.0-alpha.0",
  "description": "Shared vocabulary and canonical types for the Yakcc monorepo — contract shapes, embeddings, merkle proofs, and granularity primitives.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./source-extract": "./dist/source-extract.js",
    "./source-pick": "./dist/source-pick.js"
  },
  "private": true,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cneckar/yakcc.git",
    "directory": "packages/contracts"
  },
  "homepage": "https://github.com/cneckar/yakcc/tree/main/packages/contracts#readme",
  "bugs": {
    "url": "https://github.com/cneckar/yakcc/issues"
  },
  "keywords": [
    "yakcc",
    "contracts",
    "typescript",
    "types"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p .",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "lint": "echo \"no lint yet\""
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@xenova/transformers": "^2.17.2",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^4.7.0",
    "vitest": "^4.1.5"
  }
}
