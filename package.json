{
  "name": "yakcc",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "strict-subset": "turbo run strict-subset",
    "yakcc": "pnpm --filter @yakcc/cli exec yakcc",
    "bench:airgap": "node bench/B6-airgap/run.mjs",
    "bench:latency:integer-math": "node bench/B1-latency/integer-math/run.mjs",
    "bench:latency:json": "node bench/B1-latency/json-transformer/run.mjs",
    "bench:latency:http": "node bench/B1-latency/http-routing/run.mjs",
    "bench:latency:all": "node bench/B1-latency/integer-math/run.mjs && node bench/B1-latency/json-transformer/run.mjs && node bench/B1-latency/http-routing/run.mjs",
    "bench:coherence:slice1": "node bench/B5-coherence/harness/run-conversation.mjs && node bench/B5-coherence/rubric-eval.mjs",
    "bench:coherence:slice2": "node bench/B5-coherence/harness/run-conversation.mjs && node bench/B5-coherence/rubric-eval.mjs",
    "bench:curve-synthetic:slice1": "node bench/B8-synthetic/run.mjs",
    "bench:v0-smoke": "node bench/v0-release-smoke/smoke.mjs",
    "bench:commit": "node bench/B7-commit/harness/run.mjs",
    "bench:tokens": "node bench/B4-tokens/harness/run.mjs",
    "bench:tokens:dry": "node bench/B4-tokens/harness/run.mjs --dry-run",
    "bench:min-surface": "node bench/B9-min-surface/harness/run.mjs",
    "bench:min-surface:dry": "node bench/B9-min-surface/harness/run.mjs --dry-run",
    "bench:min-surface:no-network": "node bench/B9-min-surface/harness/run.mjs --no-network",
    "bench:import-replacement": "node bench/B10-import-replacement/harness/run.mjs",
    "bench:import-replacement:dry": "node bench/B10-import-replacement/harness/run.mjs --dry-run",
    "bench:import-replacement:no-network": "node bench/B10-import-replacement/harness/run.mjs --no-network"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "patchedDependencies": {
      "@yao-pkg/pkg@6.19.0": "patches/@yao-pkg__pkg@6.19.0.patch"
    }
  }
}
