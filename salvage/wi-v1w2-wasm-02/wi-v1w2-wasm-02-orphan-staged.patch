+  | { readonly tag: "string" }  // lowered as (ptr: i32, len: i32)
+  | {
+      readonly tag: "record";
+      readonly fields: ReadonlyArray<{ name: string; type: WasmTypeKind }>;
+      readonly offsets: ReadonlyArray<number>;
+      readonly totalSize: number;
+    } // lowered as ptr: i32
+  | {
+      readonly tag: "array";
+      readonly element: WasmTypeKind;
+      readonly elementSize: number;
+    }; // lowered as (ptr: i32, len: i32)
