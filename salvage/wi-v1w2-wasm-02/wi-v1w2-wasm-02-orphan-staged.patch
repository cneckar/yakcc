+// Cross-backend execution helpers
+//
+// These helpers implement the comparison required by the evaluation contract:
+// each parity test must assert equality between tsBackend output and wasmBackend
+// output for the same ResolutionResult.
+//
+// @decision DEC-V1-WAVE-2-WASM-TEST-004 (see file header) governs the TS type
+// stripper. The strip function handles exactly the annotation patterns used in
+// this file's substrates — no more, no less.
+// ---------------------------------------------------------------------------
+
+/**
+ * Strip TypeScript type annotations from an emitted TS module string so the
+ * result can be executed as JavaScript via new Function().
+ *
+ * Patterns stripped:
+ *   1. Inline JSDoc @wasmType annotations: /** @wasmType i32 * /
+ *   2. Parameter type annotations: `: number`, `: bigint`, `: string`,
+ *      `: boolean`, `: { a: number; b: number }`, `: Array<number>`,
+ *      `: ReadonlyArray<number>`
+ *   3. Return type annotation: `): <type> {` → `) {`
+ *   4. `import type ...` lines (type-only imports, not runtime)
+ *   5. `// ...` comment lines from the assembled module header
+ *   6. `export { name };` re-export lines (function def already has `export`)
+ *   7. `// --- block: ... ---` separator comments
+ *
+ * This is intentionally narrow — only the patterns appearing in this test
+ * file's substrates are handled.
+ */
+function stripTsTypes(source: string): string {
+  return source
+    // Remove inline JSDoc @wasmType annotations (/** @wasmType i32 */)
+    .replace(/\/\*\*\s*@wasmType\s+\w+\s*\*\/\s*/g, "")
+    // Remove import type lines
+    .replace(/^import type\s+.*$/gm, "")
+    // Remove // comment lines (assembled module header + block separators)
+    .replace(/^\/\/.*$/gm, "")
+    // Remove parameter type annotations — handles: `: number`, `: bigint`, `: string`,
+    // `: boolean`, `: void`, `: { ... }` (braced object type), `: Array<...>`,
+    // `: ReadonlyArray<...>`. Uses negative-lookahead to avoid stripping `=>`.
+    .replace(/:\s*(?:number|bigint|string|boolean|void|undefined)\b/g, "")
+    // Remove object type annotations in parameter position: `: { a: T; b: T }`
+    .replace(/:\s*\{[^}]*\}/g, "")
+    // Remove generic array type annotations: `: Array<...>` `: ReadonlyArray<...>`
+    .replace(/:\s*(?:Readonly)?Array\s*<[^>]*>/g, "")
+    // Remove function return type annotation: `):<anything>{` → `) {`
+    // Handles `): number {`, `): bigint {`, `): string {`, etc.
+    .replace(/\)\s*:[^{]+\{/g, ") {")
+    // Remove `export { name };` re-export lines
+    .replace(/^export\s*\{[^}]*\}\s*;?\s*$/gm, "")
+    // Remove `export` keyword from function declarations — `export function` is a module
+    // syntax not valid inside new Function() scope. The function becomes locally declared
+    // and is returned by name at the end of the wrapper body.
+    .replace(/\bexport\s+function\b/g, "function")
+    // Collapse multiple blank lines to one
+    .replace(/\n{3,}/g, "\n\n")
+    .trim();
+}
+
+/**
+ * Execute an emitted TS module string for a specific exported function name.
+ *
+ * Strips TS types from the source, extracts the named function via new Function(),
+ * and returns it as a callable. The function is executed in a fresh scope with no
+ * module system — only basic JS globals are available.
+ *
+ * This is safe for our substrates because they contain only arithmetic/string
+ * operations and no imports. If a substrate imports an external module, this
+ * helper will fail loudly (the import statement will be a syntax error in the
+ * Function constructor scope).
+ */
+function extractFunctionFromTsModule(
+  tsModuleSource: string,
+  funcName: string,
+): (...args: unknown[]) => unknown {
+  const stripped = stripTsTypes(tsModuleSource);
+  // Wrap in an IIFE that returns the named function.
+  // new Function body: declare function, then return it by name.
+  const wrappedBody = `${stripped}\nreturn ${funcName};`;
+  // eslint-disable-next-line no-new-func
+  const factory = new Function(wrappedBody);
+  return factory() as (...args: unknown[]) => unknown;
+}
