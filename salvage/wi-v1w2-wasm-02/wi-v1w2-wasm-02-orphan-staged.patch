+  switch (t.tag) {
+    case "i32":
+    case "boolean":
+      return [I32];
+    case "i64":
+      return [I64];
+    case "f32":
+      return [F32];
+    case "f64":
+      return [F64];
+    case "string":
+    case "array":
+      return [I32, I32]; // ptr, len
+    case "record":
