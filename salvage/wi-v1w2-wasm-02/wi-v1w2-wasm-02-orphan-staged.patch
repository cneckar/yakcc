+// P2. Parity test 2 — string→number: cross-backend equality
+//
+// TS backend: strlen("hello") = 5 (string.length, native JS)
+// WASM backend: strlen(ptr, len) where len = UTF-8 byte count = 5
+// Both backends return the byte length of the string — semantically equal.
+//
+// Compound interaction: lowerType("string") → linear-memory ptr+len params
+//   → binary emitter → WebAssembly.instantiate with shared memory → execute
+// ---------------------------------------------------------------------------
+
+describe("P2 — string→number strlen: cross-backend parity (compound)", () => {
+  const STRLEN_SOURCE = `export function strlen(s: string): number { return s.length; }`;
+
+  // 5 input strings
+  const INPUT_CASES: string[] = ["", "a", "hello", "hello world", "longer string with spaces"];
+
+  /**
+   * Execute WASM strlen by writing the UTF-8 string into memory and calling with (ptr, len).
+   */
+  async function wasmStrlen(source: string, funcName: string, s: string): Promise<number> {
+    const id = makeMerkleRoot(funcName, `String function: ${funcName}`, source);
+    const resolution = makeResolution([{ id, source }]);
+    const bytes = await compileToWasm(resolution);
+    const { instance } = await WebAssembly.instantiate(bytes);
+    const memory = instance.exports["memory"] as WebAssembly.Memory;
+    const fn = instance.exports[funcName] as (ptr: number, len: number) => number;
+    const enc = new TextEncoder();
+    const encoded = enc.encode(s);
+    const view = new Uint8Array(memory.buffer);
+    for (let i = 0; i < encoded.length; i++) view[i] = encoded[i] ?? 0;
+    return fn(0, encoded.length);
+  }
+
+  it("tsBackend and wasmBackend produce equal strlen for all 5 input strings", async () => {
+    const id = makeMerkleRoot("strlen", "String length function", STRLEN_SOURCE);
