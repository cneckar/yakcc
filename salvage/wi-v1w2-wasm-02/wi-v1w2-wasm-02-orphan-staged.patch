+  if (t === "bigint") return { tag: "i64" };
+  if (t === "void" || t === "undefined") return { tag: "i32" };
+
+  if (t === "number") {
+    const hint = (extractedHint ?? "").toLowerCase();
+    if (hint === "i32" || hint === "integer") return { tag: "i32" };
+    if (hint === "i64") return { tag: "i64" };
+    if (hint === "f32") return { tag: "f32" };
+    if (hint === "f64") return { tag: "f64" };
+    // Absent or unrecognized typeHint → default f64 + downgrade warning.
+    // This is the documented behavior per DEC-V1-WAVE-2-WASM-LOWERING-001.
