node_modules/
dist/
coverage/
.turbo/
*.tsbuildinfo
*.log
.DS_Store
.env
.env.local
# Compose-by-reference project dir (#1044, DEC-COMPOSE-BY-REF-MANIFEST-001):
# .yakcc/manifest.json is the committable authority that pins referenced atom
# content-addresses; .yakcc/atoms/ is regenerable build output (materialized by
# `yakcc build`, #1045) and must stay ignored.
.yakcc/*
!.yakcc/manifest.json
.yakccrc.json
tmp/
# NOTE: tmp/discovery-eval/baseline-single-vector-2026-05-10.json and
# tmp/discovery-eval/measurement-first-decision.md are committed via `git add --force`
# (DEC-V3-DISCOVERY-D5-HARNESS-001: operator-facing decision input must survive reboots).
# The `tmp/` rule above ignores them by default; git-add --force bypasses it for these files.
.claude/
.worktrees/

# Auto-generated by stop.sh hook from @decision annotations
DECISIONS.md
DECISIONS.md.tmp.*

# Bootstrap outputs — registry sqlite is now committed (WI-850); WAL/SHM are transient SQLite journals.
# expected-roots.json is committed separately (WI-V2-BOOTSTRAP-03).
bootstrap/yakcc.registry.sqlite-wal
bootstrap/yakcc.registry.sqlite-shm
# B4-v5 corpus — registry.sqlite is committed; WAL/SHM are transient; intent-cache is build artifact.
bench/B4-tokens-v5/corpus/*.sqlite-wal
bench/B4-tokens-v5/corpus/*.sqlite-shm
bench/B4-tokens-v5/corpus/intent-cache/
bootstrap/report.json
bootstrap/.write.lock

# B1-latency corpus — 100MB binary, content-addressed; regenerated on demand.
# corpus-spec.json (the hash) IS committed; the binary is NOT.
bench/B1-latency/integer-math/corpus/
# B1-latency Rust baseline build artifacts
bench/B1-latency/integer-math/rust-baseline/target/

# Slice 2: json-transformer corpus + Rust build artifacts
bench/B1-latency/json-transformer/corpus/
bench/B1-latency/json-transformer/rust-baseline/target/

# Slice 3: http-routing corpus + Rust build artifacts
bench/B1-latency/http-routing/corpus/
bench/B1-latency/http-routing/rust-baseline/target/

# compile-self recompiled output — generated artifact, never committed.
# Reproducible from `yakcc compile-self` (DEC-V2-CORPUS-DISTRIBUTION-001, A2 slice).
dist-recompiled/

# Stray TS build artifacts that escape into src/ when cross-package imports
# trigger out-of-tree compilation. If this pattern reappears, find the offending
# import chain rather than relying on this catch-all.
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
packages/*/src/**/*.js.map

# B5-coherence: transcripts and arm-mapping are transient; slice1-scores.json is committed.
# (DEC-BENCH-B5-SLICE1-001: per-run transcripts are ephemeral; the score JSON is operator
# decision input and must survive reboots. Committed via `git add --force`.)
tmp/B5-coherence/transcripts/
tmp/B5-coherence/arm-mapping.json
